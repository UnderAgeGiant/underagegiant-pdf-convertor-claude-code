{
  "info": {
    "name": "underagegiant-pdf-convertor-claude-code",
    "description": "API collection for the PDF/DOCX converter service. Covers all endpoints and edge cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health - OK",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Body has status ok', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json).to.have.property('timestamp');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "DOCX to PDF",
      "item": [
        {
          "name": "POST /api/convert/docx-to-pdf - Success",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/convert/docx-to-pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "convert", "docx-to-pdf"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "files/sample.docx",
                  "description": "A valid .docx file"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Content-Type is PDF', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/pdf');",
                  "});",
                  "pm.test('Content-Disposition is attachment', () => {",
                  "  pm.expect(pm.response.headers.get('Content-Disposition')).to.include('attachment');",
                  "  pm.expect(pm.response.headers.get('Content-Disposition')).to.include('.pdf');",
                  "});",
                  "pm.test('Response body is not empty', () => {",
                  "  pm.expect(pm.response.responseSize).to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/convert/docx-to-pdf - No File (400)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/convert/docx-to-pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "convert", "docx-to-pdf"]
            },
            "body": {
              "mode": "formdata",
              "formdata": []
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error status in body', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('error');",
                  "  pm.expect(json.message).to.include('No file');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/convert/docx-to-pdf - Wrong File Type (415)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/convert/docx-to-pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "convert", "docx-to-pdf"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "files/sample.pdf",
                  "description": "A non-DOCX file to trigger 415"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 415 or 500', () => {",
                  "  pm.expect([415, 500]).to.include(pm.response.code);",
                  "});",
                  "pm.test('Error status in body', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/convert/docx-to-pdf - File Too Large (413)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/convert/docx-to-pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "convert", "docx-to-pdf"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/large-file-over-50mb.docx",
                  "description": "Replace with a file exceeding the 50MB limit"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 413', () => pm.response.to.have.status(413));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/convert/docx-to-pdf - Rate Limit Exceeded (429)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/convert/docx-to-pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "convert", "docx-to-pdf"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "files/sample.docx"
                }
              ]
            },
            "description": "Run this request more than 10 times within 15 minutes to trigger the rate limiter."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rate limit headers present', () => {",
                  "  pm.expect(pm.response.headers.get('RateLimit-Limit')).to.exist;",
                  "  pm.expect(pm.response.headers.get('RateLimit-Remaining')).to.exist;",
                  "});",
                  "if (pm.response.code === 429) {",
                  "  pm.test('Status 429 - Too Many Requests', () => pm.response.to.have.status(429));",
                  "  pm.test('Error message in body', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('error');",
                  "    pm.expect(json.message).to.include('Too many');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
